PORT=5000
MONGODB_URI=mongodb://localhost:27017/college-food-ordering
JWT_SECRET=replace_with_a_strong_secret
CLIENT_URL=http://localhost:5173

RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxx

# ── Email (Resend) ────────────────────────────────────────────────────────────
# Resend uses HTTPS (port 443) — works on Render, Railway, Fly.io, Heroku, etc.
# Gmail SMTP (ports 465/587) is frequently blocked by cloud free-tier firewalls.
#
# Steps:
#   1. Create a free account at https://resend.com
#   2. Generate an API key at https://resend.com/api-keys
#   3. Add RESEND_API_KEY to your Render environment variables
#
# RESEND_FROM options:
#   • No domain verified yet  → use "onboarding@resend.dev"
#     (sandbox — only delivers to your own Resend account email)
#   • Domain verified         → use "Campus Canteen Hub <noreply@yourdomain.com>"
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM=Campus Canteen Hub <noreply@yourdomain.com>

TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=your_twilio_phone_number
